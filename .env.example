# TungkiAsu — environment template
#
# Copy to /root/.agent/credentials/ as separate files (or adjust paths in worker.py / bot.py),
# then chmod 600 each one. Never commit real values.

# ─── Telegram bot ─────────────────────────────────────────────────────────────
# Path: /root/.agent/credentials/mimosubmit_bot.env
# Format:
#   BOT_TOKEN=123456:AA....
#   BOT_OWNER_ID=6219883976           # numeric Telegram user id of the owner
BOT_TOKEN=put_your_telegram_bot_token_here
BOT_OWNER_ID=0

# ─── GitHub auth (for `gh repo create --push`) ────────────────────────────────
# Path: /root/.agent/credentials/github.env
# Format:
#   GITHUB_TOKEN=ghp_...               # PAT with repo scope (public + private)
GITHUB_TOKEN=ghp_put_your_token_here

# ─── Vercel CLI (one-time login, no env file needed) ──────────────────────────
# Run once on the host:  vercel-cli login
# Token persisted at:    ~/.local/share/com.vercel.cli/auth.json
# (worker shells out to /usr/local/bin/vercel-cli)

# ─── MiMo submit script (CloakBrowser + 2captcha + WARP) ──────────────────────
# The mimo_submit_generic.py script ships in the hermes-agent repo. It needs:
#   - CloakBrowser venv at /tmp/cloak_venv (or set CLOAK_PY in worker.py)
#   - 2captcha API key inside the script's own env (see that script's docs)
#   - WARP socks5 proxy on 127.0.0.1:40000  (warp-cli set-mode proxy && warp-cli connect)
CLOAK_PY=/tmp/cloak_venv/bin/python
SUBMIT_SCRIPT=/root/.hermes/skills/crypto/mimo-100t-form/scripts/mimo_submit_generic.py
WARP_PROXY=socks5://127.0.0.1:40000

# ─── GitHub identity used for the auto commits ────────────────────────────────
GITHUB_USER=YourGitHubUsername
GIT_COMMIT_EMAIL=you@example.com
